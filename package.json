{
  "name": "dark-messenger",
  "version": "1.0.4",
  "description": "Dark Messenger",
  "main": "main.js",
  "author": "titov",
  "license": "MIT",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build-exe": "electron-builder --win nsis"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "electron-updater": "^6.1.8",
    "express": "^4.18.2",
    "lowdb": "^7.0.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.dark.messenger",
    "productName": "Dark Messenger",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ilizeum",
        "repo": "dark-messenger"
      }
    ]
  }
}