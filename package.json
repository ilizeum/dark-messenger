{
  "name": "callibri",
  "version": "2.0.2",
  "description": "Callibri",
  "main": "main.js",
  "author": "titov",
  "license": "MIT",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build-exe": "electron-builder --win nsis"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "electron-updater": "^6.1.8",
    "express": "^4.18.2",
    "lowdb": "^7.0.1",
    "pg": "^8.20.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ilizeum.callibri",
    "productName": "Callibri",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "public/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Callibri",
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ilizeum",
        "repo": "dark-messenger"
      }
    ]
  }
}