{
  "name": "dark-messenger",
  "version": "1.0.0",
  "description": "Dark Messenger App",
  "main": "main.js",
  "author": "titov",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build-exe": "electron-builder --win nsis"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.5",
    "electron-updater": "^6.1.8"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "dark.messenger.app",
    "productName": "Dark Messenger",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "package.json",
      "public/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ilizeum",
        "repo": "dark-messenger"
      }
    ]
  }
}